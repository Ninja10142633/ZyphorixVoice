# Variáveis de ambiente do ZyphorixVoice
# Copie este arquivo para .env e preencha os valores

# ── Geral ─────────────────────────────────────────────────────
DEBUG=false

# ── Áudio ─────────────────────────────────────────────────────
DEFAULT_MICROPHONE=Microfone padrão do sistema

# ── Tradução ──────────────────────────────────────────────────
SOURCE_LANG=pt
TARGET_LANG=en
TRANSLATION_ENGINE=none

# ── APIs (preencher quando implementar) ───────────────────────
# OPENAI_API_KEY=sk-...
# ELEVENLABS_API_KEY=...
# DEEPL_API_KEY=...
